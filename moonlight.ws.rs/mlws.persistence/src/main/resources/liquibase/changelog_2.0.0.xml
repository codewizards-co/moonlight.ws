	<changeSet id="2026-01-07_mh_01" author="mh">
		<sql>
			update "Invoice" set
				"includedTotalGross" = (
					select coalesce(sum(coalesce("priceTotalGross", 0)), 0)
					from "InvoiceItem"
					where
						"InvoiceItem"."invoiceId" = "Invoice"."id"
						and "InvoiceItem"."deleted" = 0
						and "InvoiceItem"."include" = 'I' 
				)
			;

			update "Invoice" set
				"includedTotalNet" = (
					select coalesce(sum(coalesce("priceTotalNet", 0)), 0)
					from "InvoiceItem"
					where
						"InvoiceItem"."invoiceId" = "Invoice"."id"
						and "InvoiceItem"."deleted" = 0
						and "InvoiceItem"."include" = 'I' 
				)
			;

			update "Invoice" set
				"excludedTotalGross" = (
					select coalesce(sum(coalesce("priceTotalGross", 0)), 0)
					from "InvoiceItem"
					where
						"InvoiceItem"."invoiceId" = "Invoice"."id"
						and "InvoiceItem"."deleted" = 0
						and "InvoiceItem"."include" = 'X' 
				)
			;

			update "Invoice" set
				"excludedTotalNet" = (
					select coalesce(sum(coalesce("priceTotalNet", 0)), 0)
					from "InvoiceItem"
					where
						"InvoiceItem"."invoiceId" = "Invoice"."id"
						and "InvoiceItem"."deleted" = 0
						and "InvoiceItem"."include" = 'X' 
				)
			;
		</sql>
	</changeSet>

