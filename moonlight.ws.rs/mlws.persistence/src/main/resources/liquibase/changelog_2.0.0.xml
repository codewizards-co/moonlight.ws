			<column name="includedTotalNet" type="numeric(15, 2)" defaultValue="0">
				<constraints nullable="false" />
			</column>
			<column name="includedTotalGross" type="numeric(15, 2)" defaultValue="0">
				<constraints nullable="false" />
			</column>
			<column name="excludedTotalNet" type="numeric(15, 2)" defaultValue="0">
				<constraints nullable="false" />
			</column>
			<column name="excludedTotalGross" type="numeric(15, 2)" defaultValue="0">
